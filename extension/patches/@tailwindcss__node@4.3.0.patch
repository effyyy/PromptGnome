+fi
+if [ -x "$basedir/node" ]; then
+  exec "$basedir/node"  "$basedir/../../../../../../jiti@2.7.0/node_modules/jiti/lib/jiti-cli.mjs" "$@"
+else
+  exec node  "$basedir/../../../../../../jiti@2.7.0/node_modules/jiti/lib/jiti-cli.mjs" "$@"
