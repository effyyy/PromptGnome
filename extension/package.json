{
  "name": "promptgnome",
  "displayName": "PromptGnome",
  "version": "1.0.0",
  "description": "Detects sensitive information in your messages to AI chatbots and warns you before sending.",
  "author": "effyyy <contact@promptgnome.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv3",
    "build:edge": "plasmo build --target=edge-mv3",
    "package": "plasmo build && plasmo package",
    "package:firefox": "plasmo build --target=firefox-mv3 && plasmo package --target=firefox-mv3",
    "package:edge": "plasmo build --target=edge-mv3 && plasmo package --target=edge-mv3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "benchmark": "vitest run benchmarks/"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "ibantools": "^4.5.4",
    "libphonenumber-js": "^1.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitest/coverage-v8": "^4.1.7",
    "ajv": "^8.20.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "path-browserify": "^1.0.1",
    "plasmo": "^0.90.5",
    "playwright": "^1.59.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "url": "^0.11.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "manifest": {
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "permissions": [
      "storage",
      "sidePanel",
      "alarms",
      "offscreen"
    ],
    "host_permissions": [
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://claude.ai/*",
      "https://gemini.google.com/*",
      "https://chat.deepseek.com/*",
      "https://www.perplexity.ai/*",
      "https://perplexity.ai/*",
      "https://grok.com/*",
      "https://x.com/i/grok*",
      "https://copilot.microsoft.com/*",
      "https://www.meta.ai/*",
      "https://meta.ai/*"
    ]
  },
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/effyyy/PromptGnome.git",
    "directory": "extension"
  },
  "bugs": {
    "url": "https://github.com/effyyy/PromptGnome/issues"
  },
  "homepage": "https://promptgnome.com",
  "pnpm": {
    "overrides": {
      "protobufjs": "7.5.8",
      "@parcel/reporter-dev-server": "2.16.4",
      "content-security-policy-parser": "0.6.0",
      "esbuild": "0.28.0",
      "msgpackr": "1.11.9",
      "svelte": "5.55.9",
      "tsup": "8.5.1",
      "vite": "8.0.14",
      "picomatch@<4.0.0": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@>=1.0.0 <2.0.0": "1.10.3",
      "yaml@>=2.0.0 <2.8.3": "2.9.0",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6"
    },
    "patchedDependencies": {
      "jiti@2.7.0": "patches/jiti@2.7.0.patch",
      "@tailwindcss/oxide@4.3.0": "patches/@tailwindcss__oxide@4.3.0.patch",
      "@tailwindcss/node@4.3.0": "patches/@tailwindcss__node@4.3.0.patch",
      "tailwindcss@4.3.0": "patches/tailwindcss@4.3.0.patch",
      "@parcel/reporter-dev-server@2.16.4": "patches/@parcel__reporter-dev-server@2.16.4.patch"
    }
  }
}
