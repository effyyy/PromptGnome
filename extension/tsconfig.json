{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": ["node_modules", "backend"],
  "include": [".plasmo/index.d.ts", "./**/*.ts", "./**/*.tsx"],
  "compilerOptions": {
    "strict": true,
    "paths": {
      "~*": ["./*"]
    },
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "types": ["chrome", "node"],
    "ignoreDeprecations": "6.0"
  }
}
